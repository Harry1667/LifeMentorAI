# ============================================================
# AI Proxy .env 標準寫法
# 複製此檔案為 .env 並填入你的設定：cp .env.example .env
#
# 注意：
#   - 值不加引號（AI_PROXY_HOST=cli.twloop.com ✅）
#   - 不要有空格（AI_PROXY_HOST = cli.twloop.com ❌）
#   - 舊版 AI_PROXY_GRPC_HOST / AI_PROXY_GRPC_PORT 仍可用（向下相容）
# ============================================================

# === 必填 ===

AI_PROXY_HOST=cli.twloop.com
AI_PROXY_PORT=443
AI_PROXY_TLS=true
AI_PROXY_TOKEN=貼上你的token
AI_PROXY_PROJECT=你的專案名

# Server-side 模型管理（開啟後 tier 由 server 解析，不用設定下面的模型）
# AI_PROXY_SERVER_TIER=true

# === 基本設定 ===

# 預設 AI provider（不指定時用 claude）
AI_PROXY_PROVIDER=claude

# 預設小組（可選，專案內細分用量統計）
# AI_PROXY_GROUP=

# 自動路由（預設開啟）：分析 prompt 自動選 high/mid/fast
# 關閉後不指定 tier 時一律用預設模型
# AI_PROXY_AUTO_ROUTE=true

# === 預設模型 ===
# 不指定 model 或 tier 時使用，每個 provider 一個

AI_PROXY_CLAUDE_MODEL=claude-sonnet-4-6
AI_PROXY_GEMINI_MODEL=gemini-2.5-flash
AI_PROXY_OPENAI_MODEL=gpt-4o-mini
AI_PROXY_DEEPSEEK_MODEL=deepseek-chat
AI_PROXY_MISTRAL_MODEL=mistral-small-latest
AI_PROXY_GROQ_MODEL=llama-3.3-70b-versatile
AI_PROXY_XAI_MODEL=grok-3-mini
AI_PROXY_TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
AI_PROXY_FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
AI_PROXY_COHERE_MODEL=command-r-plus

# === 模型等級（tier）===
# 用 ai("問題", tier="high") 自動對應下面的模型
# 新模型推出時改這裡就好，呼叫端不用動
#
# 用法：
#   ai("複雜分析", tier="high")   → claude-opus-4-6
#   ai("一般任務", tier="mid")    → claude-sonnet-4-6
#   ai("簡單問答", tier="fast")   → claude-haiku-4-5
#   ai("用 Gemini", tier="high", provider="gemini") → gemini-2.5-pro

# Claude
AI_PROXY_CLAUDE_HIGH=claude-opus-4-6
AI_PROXY_CLAUDE_MID=claude-sonnet-4-6
AI_PROXY_CLAUDE_FAST=claude-haiku-4-5

# Gemini
AI_PROXY_GEMINI_HIGH=gemini-2.5-pro
AI_PROXY_GEMINI_MID=gemini-2.5-flash
AI_PROXY_GEMINI_FAST=gemini-2.5-flash-lite

# OpenAI
AI_PROXY_OPENAI_HIGH=gpt-4o
AI_PROXY_OPENAI_MID=gpt-4o-mini
AI_PROXY_OPENAI_FAST=gpt-4o-mini

# DeepSeek
AI_PROXY_DEEPSEEK_HIGH=deepseek-reasoner
AI_PROXY_DEEPSEEK_MID=deepseek-chat
AI_PROXY_DEEPSEEK_FAST=deepseek-chat

# Mistral
AI_PROXY_MISTRAL_HIGH=mistral-large-latest
AI_PROXY_MISTRAL_MID=mistral-small-latest
AI_PROXY_MISTRAL_FAST=mistral-small-latest

# Groq
AI_PROXY_GROQ_HIGH=llama-3.3-70b-versatile
AI_PROXY_GROQ_MID=llama-3.1-8b-instant
AI_PROXY_GROQ_FAST=llama-3.1-8b-instant

# xAI/Grok
AI_PROXY_XAI_HIGH=grok-3
AI_PROXY_XAI_MID=grok-3-mini
AI_PROXY_XAI_FAST=grok-3-mini

# Together AI
AI_PROXY_TOGETHER_HIGH=meta-llama/Llama-3.3-70B-Instruct-Turbo
AI_PROXY_TOGETHER_MID=meta-llama/Llama-3.3-70B-Instruct-Turbo
AI_PROXY_TOGETHER_FAST=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Fireworks AI
AI_PROXY_FIREWORKS_HIGH=accounts/fireworks/models/llama-v3p3-70b-instruct
AI_PROXY_FIREWORKS_MID=accounts/fireworks/models/llama-v3p3-70b-instruct
AI_PROXY_FIREWORKS_FAST=accounts/fireworks/models/llama-v3p1-8b-instruct

# Cohere
AI_PROXY_COHERE_HIGH=command-r-plus
AI_PROXY_COHERE_MID=command-r
AI_PROXY_COHERE_FAST=command-r

# === 進階設定（通常不需要改）===

# Quota Fallback — provider 失敗時自動嘗試下一個
# AI_PROXY_FALLBACK=true
# AI_PROXY_FALLBACK_CHAIN=gemini,deepseek,groq

# 敏感資料過濾 — 偵測 prompt 中的 API Key/密碼
# AI_PROXY_SENSITIVE_CHECK=true
# AI_PROXY_SENSITIVE_MODE=warn

# 媒體生成（Gemini 專用，走 REST API）
# 需要 server 端設定 GEMINI_API_KEY
# AI_PROXY_DASHBOARD_PORT=443
# AI_PROXY_GEMINI_IMAGE=gemini-2.5-flash-image
# AI_PROXY_GEMINI_VIDEO=veo-3.0-generate-001
# AI_PROXY_GEMINI_TTS=gemini-2.5-flash-preview-tts
# AI_PROXY_GEMINI_MUSIC=lyria-3-clip-preview

# 通知（長任務完成後通知，設一個就好）
# AI_PROXY_NOTIFY_TELEGRAM=https://api.telegram.org/bot你的TOKEN/sendMessage?chat_id=你的CHATID
# AI_PROXY_NOTIFY_DISCORD=https://discord.com/api/webhooks/你的WEBHOOK
# AI_PROXY_NOTIFY_SLACK=https://hooks.slack.com/services/你的WEBHOOK
